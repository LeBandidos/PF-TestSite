RewriteEngine On

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} ^[A-Z]+\ /index\.html
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /home to /
RewriteRule ^home/?$ / [R=301,L]

# Redirect old /palmares URL to /realizari
RewriteRule ^palmares/?$ /realizari [R=301,L]

# Redirect old /concursuri/editia-1 URL (old directory name) to the new one
RewriteRule ^concursuri/([^/]+)/?$ /concursuri-editii/$1 [R=301,L]

# Serve clean URLs: /concursuri-editii/editia-1 → concursuri-editii/editia-1.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^concursuri-editii/([^/]+)/?$ concursuri-editii/$1.html [L]

# Serve clean URLs: /contact → contact.html, /privacy-policy → privacy-policy.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]
